<UserControl
    x:Class="Pokemon_Like.MVVM.View.LoginView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Pokemon_Like.MVVM.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <StackPanel Margin="50" VerticalAlignment="Center">
            <Label Content="Username" FontSize="24" />
            <TextBlock
                Width="700"
                Margin="0,0,0,20"
                HorizontalAlignment="Left"
                FontSize="24" />
            <Label Content="Password" FontSize="24" />
            <PasswordBox
                Width="700"
                Margin="0,0,0,20"
                HorizontalAlignment="Left"
                FontSize="24" />
            <Button
                Width="100"
                HorizontalAlignment="Center"
                Content="Login" />
        </StackPanel>
    </Grid>
</UserControl>
